{
  "compilerOptions": {
    "target": "es2017",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "importHelpers": true,
    "isolatedModules": true,
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["svelte", "node"],
    "lib": ["ESNext", "DOM"]
  },
  "include": ["src/**/*", "svelte-custom.d.ts"]
}
